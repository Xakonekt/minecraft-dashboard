# Port for the agent API
PORT=3001

# Docker socket path (Linux default)
DOCKER_SOCKET=/var/run/docker.sock

# Discord Webhook (optional — leave empty to disable)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXX
# Notify on player join/leave (true | false)
DISCORD_NOTIFY_PLAYERS=true

# ── Servers are configured in servers.json (not here) ─────────────────────
# Copy servers.json.example → servers.json and fill in your server details.
