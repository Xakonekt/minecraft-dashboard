# Port for the agent API
PORT=3001

# Docker socket path (Linux default)
DOCKER_SOCKET=/var/run/docker.sock

# Container name (as defined in docker-compose)
CONTAINER_NAME=minecraft

# RCON connection settings
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=Password

# Server type: vanilla | forge | neoforge | paper | spigot | fabric
SERVER_TYPE=neoforge

# Discord Webhook (optional)
# Laisser vide pour désactiver les notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXX
# Notifier les connexions/déconnexions de joueurs (true | false)
DISCORD_NOTIFY_PLAYERS=true
